  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@index([vendorId])
  @@index([invoiceDate])
  @@map("purchase_invoices")
}

model PurchaseInvoiceItem {
  id            String   @id @default(cuid())
  purchaseInvoiceId String @map("purchase_invoice_id")
  productId     String   @map("product_id")
  
  quantity      Decimal  @db.Decimal(18, 4)
  unitPrice     Decimal  @db.Decimal(18, 2) @map("unit_price")
  discountPercent Decimal @default(0) @db.Decimal(5, 2) @map("discount_percent")
  discountAmount Decimal @default(0) @db.Decimal(18, 2) @map("discount_amount")
  subtotal      Decimal  @db.Decimal(18, 2)
  totalAmount   Decimal  @db.Decimal(18, 2) @map("total_amount")
  
  description   String?  @db.VarChar(500)
  
  @@index([purchaseInvoiceId])
  @@map("purchase_invoice_items")
}

// ═══════════════════════════════════════════════════════════════
// WORK ORDER (Pekerjaan Pesanan)
// ═══════════════════════════════════════════════════════════════

model WorkOrder {
  id            String   @id @default(cuid())
  orderNumber   String   @unique @db.VarChar(30) @map("order_number")
  orderDate     DateTime @db.Date @map("order_date")
  
  customerId    String?  @map("customer_id")
  status        String   @default("DRAFT")
  
  targetProduct String?  @db.VarChar(200) @map("target_product")
  targetQuantity Decimal? @db.Decimal(18, 4) @map("target_quantity")
  
  notes         String?  @db.Text
  
  journalEntryId String? @map("journal_entry_id")
  
  createdBy     String   @db.VarChar(50) @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@map("work_orders")
}

model WorkOrderItem {
  id            String   @id @default(cuid())
  workOrderId   String   @map("work_order_id")
  productId     String   @map("product_id")
  
  quantity      Decimal  @db.Decimal(18, 4)
  unit          String   @db.VarChar(20)
  
  description   String?  @db.VarChar(500)
  
  @@index([workOrderId])
  @@map("work_order_items")
}

// ═══════════════════════════════════════════════════════════════
// WORK COMPLETION (Penyelesaian Pesanan)
// ═══════════════════════════════════════════════════════════════

model WorkCompletion {
  id            String   @id @default(cuid())
  completionNumber String @unique @db.VarChar(30) @map("completion_number")
  completionDate DateTime @db.Date @map("completion_date")
  
  workOrderId   String   @map("work_order_id")
  rollOverType  String   @default("BARANG") @map("roll_over_type")
  status        String   @default("DRAFT")
  portion       Decimal  @default(100) @db.Decimal(5, 2)
  
  notes         String?  @db.Text
  
  journalEntryId String? @map("journal_entry_id")
  
  createdBy     String   @db.VarChar(50) @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@map("work_completions")
}

model WorkCompletionItem {
  id            String   @id @default(cuid())
  workCompletionId String @map("work_completion_id")
  productId     String   @map("product_id")
  
  quantity      Decimal  @db.Decimal(18, 4)
  unit          String   @db.VarChar(20)
  allocationAmount Decimal @default(0) @db.Decimal(18, 2) @map("allocation_amount")
  
  description   String?  @db.VarChar(500)
  
  @@index([workCompletionId])
  @@map("work_completion_items")
}

// ═══════════════════════════════════════════════════════════════
// STOCK ADJUSTMENT (Penyesuaian Persediaan)
// ═══════════════════════════════════════════════════════════════

model StockAdjustment {
  id            String   @id @default(cuid())
  adjustmentNumber String @unique @db.VarChar(30) @map("adjustment_number")
  adjustmentDate DateTime @db.Date @map("adjustment_date")
  
  status        String   @default("DRAFT")
  notes         String?  @db.Text
  
  journalEntryId String? @map("journal_entry_id")
  
  createdBy     String   @db.VarChar(50) @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@map("stock_adjustments")
}

model StockAdjustmentItem {
  id            String   @id @default(cuid())
  stockAdjustmentId String @map("stock_adjustment_id")
  productId     String   @map("product_id")
  
  adjustmentType String  @map("adjustment_type") // MASUK, KELUAR
  quantity      Decimal  @db.Decimal(18, 4)
  unit          String   @db.VarChar(20)
  unitCost      Decimal  @db.Decimal(18, 2) @map("unit_cost")
  totalCost     Decimal  @db.Decimal(18, 2) @map("total_cost")
  
  description   String?  @db.VarChar(500)
  
  @@index([stockAdjustmentId])
  @@map("stock_adjustment_items")
}

// ═══════════════════════════════════════════════════════════════
// PAYMENT (Pembayaran)
// ═══════════════════════════════════════════════════════════════

model Payment {
  id            String   @id @default(cuid())
  paymentNumber String   @unique @db.VarChar(30) @map("payment_number")
  paymentDate   DateTime @db.Date @map("payment_date")
  
  bankAccountId String   @map("bank_account_id")
  vendorId      String?  @map("vendor_id")
  status        String   @default("DRAFT")
  amount        Decimal  @db.Decimal(18, 2)
  checkNumber   String?  @db.VarChar(50) @map("check_number")
  description   String?  @db.VarChar(500)
  
  journalEntryId String? @map("journal_entry_id")
  
  createdBy     String   @db.VarChar(50) @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@map("payments")
}

// ═══════════════════════════════════════════════════════════════
// RECEIPT (Penerimaan)
// ═══════════════════════════════════════════════════════════════

model Receipt {
