  amount        Decimal  @db.Decimal(18, 2)
  description   String?  @db.VarChar(500)
  
  journalEntryId String? @map("journal_entry_id")
  
  createdBy     String   @db.VarChar(50) @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@map("bank_transfers")
}

// ═══════════════════════════════════════════════════════════════
// BANK RECONCILIATION (Rekonsiliasi Bank)
// ═══════════════════════════════════════════════════════════════

model BankReconciliation {
  id            String   @id @default(cuid())
  reconciliationNumber String @unique @db.VarChar(30) @map("reconciliation_number")
  reconciliationDate DateTime @db.Date @map("reconciliation_date")
  
  bankAccountId String   @map("bank_account_id")
  startDate     DateTime @db.Date @map("start_date")
  endDate       DateTime @db.Date @map("end_date")
  
  bookBalance   Decimal  @db.Decimal(18, 2) @map("book_balance")
  bankBalance   Decimal  @db.Decimal(18, 2) @map("bank_balance")
  
  reconciledBookBalance Decimal @db.Decimal(18, 2) @map("reconciled_book_balance")
  reconciledBankBalance Decimal @db.Decimal(18, 2) @map("reconciled_bank_balance")
  
  status        String   @default("DRAFT")
  
  createdBy     String   @db.VarChar(50) @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@map("bank_reconciliations")
}

// ═══════════════════════════════════════════════════════════════
// FIXED ASSET (Aset Tetap)
// ═══════════════════════════════════════════════════════════════

model FixedAsset {
  id            String   @id @default(cuid())
  assetNumber   String   @unique @db.VarChar(30) @map("asset_number")
  name          String   @db.VarChar(200)
  
  purchaseDate  DateTime @db.Date @map("purchase_date")
  useDate       DateTime @db.Date @map("use_date")
  
  purchasePrice Decimal  @db.Decimal(18, 2) @map("purchase_price")
  residualValue Decimal  @default(0) @db.Decimal(18, 2) @map("residual_value")
  
  usefulLifeYears Int    @db.SmallInt @map("useful_life_years")
  usefulLifeMonths Int   @default(0) @db.SmallInt @map("useful_life_months")
  quantity      Int      @default(1)
  
  depreciationMethod String @default("STRAIGHT_LINE") @map("depreciation_method")
  depreciationRate Decimal @default(0) @db.Decimal(5, 2) @map("depreciation_rate")
  
  isIntangible  Boolean  @default(false) @map("is_intangible")
  
  assetAccountId String  @map("asset_account_id")
  accumulatedDeprAccountId String @map("accumulated_depr_account_id")
  expenseAccountId String @map("expense_account_id")
  
  currentBookValue Decimal @db.Decimal(18, 2) @map("current_book_value")
  accumulatedDepreciation Decimal @default(0) @db.Decimal(18, 2) @map("accumulated_depreciation")
  
  status        String   @default("ACTIVE")
  
  journalEntryId String? @map("journal_entry_id")
  
  createdBy     String   @db.VarChar(50) @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@map("fixed_assets")
}

model AssetDepreciation {
  id            String   @id @default(cuid())
  fixedAssetId  String   @map("fixed_asset_id")
  
  periodYear    Int      @db.SmallInt @map("period_year")
  periodMonth   Int      @db.SmallInt @map("period_month")
  
  depreciationAmount Decimal @db.Decimal(18, 2) @map("depreciation_amount")
  accumulatedDepreciation Decimal @db.Decimal(18, 2) @map("accumulated_depreciation")
  bookValue     Decimal  @db.Decimal(18, 2) @map("book_value")
  
  isPosted      Boolean  @default(false) @map("is_posted")
  journalEntryId String? @map("journal_entry_id")
  
  createdAt     DateTime @default(now()) @map("created_at")
  
  @@unique([fixedAssetId, periodYear, periodMonth])
  @@map("asset_depreciations")
}

// ═══════════════════════════════════════════════════════════════
// AUTO-NUMBERING SEQUENCE
// ═══════════════════════════════════════════════════════════════

model Sequence {
  id            String   @id @default(cuid())
  sequenceName  String   @unique @map("sequence_name") @db.VarChar(100)
  description   String?  @db.VarChar(200)
  prefix        String   @db.VarChar(20)
  formatPattern String   @db.VarChar(100) @map("format_pattern")
  currentNumber BigInt   @default(0) @map("current_number")
  incrementBy   Int      @default(1) @map("increment_by")
  minLength     Int      @default(1) @map("min_length")
  resetPeriod   String   @default("NEVER") @map("reset_period")
  isActive      Boolean  @default(true)
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@map("sequences")
}

// ═══════════════════════════════════════════════════════════════
// FISCAL PERIOD
// ═══════════════════════════════════════════════════════════════

model FiscalPeriod {
  id            String   @id @default(cuid())
  year          Int      @db.SmallInt
  month         Int      @db.SmallInt
  startDate     DateTime @db.Date @map("start_date")
  endDate       DateTime @db.Date @map("end_date")
  status        String   @default("OPEN")
  isClosed      Boolean  @default(false) @map("is_closed")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@unique([year, month])
  @@map("fiscal_periods")
}
