  receiptNumber String   @unique @db.VarChar(30) @map("receipt_number")
  receiptDate   DateTime @db.Date @map("receipt_date")
  
  bankAccountId String   @map("bank_account_id")
  customerId    String?  @map("customer_id")
  status        String   @default("DRAFT")
  amount        Decimal  @db.Decimal(18, 2)
  description   String?  @db.VarChar(500)
  
  journalEntryId String? @map("journal_entry_id")
  
  createdBy     String   @db.VarChar(50) @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@map("receipts")
}

// ═══════════════════════════════════════════════════════════════
// BANK TRANSFER (Transfer Bank)
// ═══════════════════════════════════════════════════════════════

model BankTransfer {
  id            String   @id @default(cuid())
  transferNumber String @unique @db.VarChar(30) @map("transfer_number")
  transferDate  DateTime @db.Date @map("transfer_date")
  
  fromAccountId String   @map("from_account_id")
